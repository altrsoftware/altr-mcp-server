{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-07-09/server.schema.json",
  "name": "io.github.altrsoftware/altr-mcp-server",
  "description": "MCP server for ALTR data security — 135 tools across 13 domains: databases, tags, policies, classification, access management, access requests, audits, telemetry, and sidecar configuration",
  "version": "0.4.0",
  "repository": {
    "url": "https://github.com/altrsoftware/altr-mcp-server",
    "source": "github",
    "id": 1166051012
  },
  "packages": [
    {
      "registry_type": "pypi",
      "identifier": "altr-mcp",
      "version": "0.4.0",
      "runtime_hint": "uvx",
      "runtime_arguments": [
        {
          "type": "positional",
          "value": "altr-mcp"
        }
      ],
      "environment_variables": [
        {
          "name": "ORG_ID",
          "description": "ALTR organization ID (required)"
        },
        {
          "name": "MAPI_KEY",
          "description": "ALTR management API key (required)"
        },
        {
          "name": "MAPI_SECRET",
          "description": "ALTR management API secret (required)"
        }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ]
}
