{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.altrsoftware/altr-mcp-server",
  "description": "MCP server for ALTR data security: databases, tags, policies, classification, access, audits",
  "version": "0.5.1",
  "repository": {
    "url": "https://github.com/altrsoftware/altr-mcp-server",
    "source": "github",
    "id": "1166051012"
  },
  "packages": [
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "altr-mcp",
      "version": "0.5.1",
      "runtimeHint": "uvx",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "ORG_ID",
          "description": "ALTR organization ID",
          "isRequired": true,
          "format": "string"
        },
        {
          "name": "MAPI_KEY",
          "description": "ALTR management API key",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        },
        {
          "name": "MAPI_SECRET",
          "description": "ALTR management API secret",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        }
      ]
    }
  ]
}
